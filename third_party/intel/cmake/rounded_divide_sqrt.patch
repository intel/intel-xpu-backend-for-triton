diff --git a/lib/SPIRV/SPIRVWriter.cpp b/lib/SPIRV/SPIRVWriter.cpp
index 83470eb4..a64e8293 100644
--- a/lib/SPIRV/SPIRVWriter.cpp
+++ b/lib/SPIRV/SPIRVWriter.cpp
@@ -3345,8 +3345,25 @@ bool LLVMToSPIRVBase::transDecoration(Value *V, SPIRVValue *BV) {
   if (Instruction *Inst = dyn_cast<Instruction>(V)) {
     if (shouldTryToAddMemAliasingDecoration(Inst))
       transMemAliasingINTELDecorations(Inst, BV);
-    if (auto *IDecoMD = Inst->getMetadata(SPIRV_MD_DECORATIONS))
+    if (auto *IDecoMD = Inst->getMetadata(SPIRV_MD_DECORATIONS)) {
       transMetadataDecorations(IDecoMD, BV);
+      // Check if FPRoundingMode decoration is applied to fdiv or sqrt call,
+      // which requires SPV_INTEL_rounded_divide_sqrt.
+      if (BM->isAllowedToUseExtension(
+              ExtensionID::SPV_INTEL_rounded_divide_sqrt)) {
+        bool isFDivOrSqrt = Inst->getOpcode() == Instruction::FDiv;
+        if (!isFDivOrSqrt) {
+          if (auto *CI = dyn_cast<CallInst>(Inst))
+            if (Function *F = CI->getCalledFunction())
+              if (F->getName().contains("sqrt"))
+                isFDivOrSqrt = true;
+        }
+        if (isFDivOrSqrt && BV->hasDecorate(DecorationFPRoundingMode)) {
+          BM->addCapability(internal::CapabilityRoundedDivideSqrtINTEL);
+          BM->addExtension(ExtensionID::SPV_INTEL_rounded_divide_sqrt);
+        }
+      }
+    }
     if (BV->isInst())
       addFPBuiltinDecoration(BM, Inst, static_cast<SPIRVInstruction *>(BV));
   }
