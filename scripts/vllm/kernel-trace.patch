+# Triton kernel -> tests recorder.
+#
+# Enable by setting VLLM_TRITON_KERNEL_TRACE=<output.json>.
+# Restrict to a subset of kernels with VLLM_TRITON_KERNEL_TRACE_NAMES=k1,k2
+# (comma-separated). If unset, every kernel launch is recorded.
+#
+# Output format: {"kernel_name": ["test_nodeid", ...], ...}
+_KERNEL_TRACE_HITS: dict[str, set[str]] = {}
+_KERNEL_TRACE_WATCH: set[str] | None = None
+_KERNEL_TRACE_HOOK_INSTALLED = False
+
+
+def _kernel_trace_hook(metadata) -> None:
+    name = metadata.get("name")
+    if not isinstance(name, str):
+        return
+    if _KERNEL_TRACE_WATCH is not None and name not in _KERNEL_TRACE_WATCH:
+        return
+    test_id = os.environ.get("PYTEST_CURRENT_TEST", "<no-test>")
+    # PYTEST_CURRENT_TEST has a trailing " (call)"/"(setup)" stage suffix.
+    test_id = test_id.rsplit(" (", 1)[0]
+    _KERNEL_TRACE_HITS.setdefault(name, set()).add(test_id)
+
+
+def pytest_configure(config):
+    global _KERNEL_TRACE_WATCH, _KERNEL_TRACE_HOOK_INSTALLED
+    if not os.environ.get("VLLM_TRITON_KERNEL_TRACE"):
+        return
+    names = os.environ.get("VLLM_TRITON_KERNEL_TRACE_NAMES", "").strip()
+    _KERNEL_TRACE_WATCH = (
+        {n.strip() for n in names.split(",") if n.strip()} if names else None
+    )
+    try:
+        import triton
+    except ImportError:
+        return
+    triton.knobs.runtime.launch_enter_hook.add(_kernel_trace_hook)
+    _KERNEL_TRACE_HOOK_INSTALLED = True
+
+
+def pytest_sessionfinish(session, exitstatus):
+    if not _KERNEL_TRACE_HOOK_INSTALLED:
+        return
+    out_path = os.environ.get("VLLM_TRITON_KERNEL_TRACE")
+    if not out_path:
+        return
+    payload = {k: sorted(v) for k, v in sorted(_KERNEL_TRACE_HITS.items())}
+    with open(out_path, "w") as f:
+        json.dump(payload, f, indent=2)
+
+
 def pytest_collection_modifyitems(config, items):
     if config.getoption("--optional"):
         # --optional given in cli: do not skip optional tests
