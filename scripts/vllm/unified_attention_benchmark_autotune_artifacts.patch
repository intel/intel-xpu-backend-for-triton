+def _write_csv_rows(report_path: str, fieldnames: list[str],
+                    rows: list[dict[str, object]]) -> None:
+    if not rows:
+        return
+
+    write_header = not os.path.exists(report_path) or os.path.getsize(report_path) == 0
+    if not write_header:
+        with open(report_path, newline='', encoding='utf-8') as report_file:
+            existing_header = next(csv.reader(report_file), [])
+        if existing_header != fieldnames:
+            raise RuntimeError(
+                f'Refusing to append incompatible autotune artifact schema to {report_path}'
+            )
+    with open(report_path, 'a', newline='', encoding='utf-8') as report_file:
+        writer = csv.DictWriter(report_file, fieldnames=fieldnames, extrasaction='ignore')
+        if write_header:
+            writer.writeheader()
+        writer.writerows(rows)
+    print(f'Wrote unified attention autotune artifacts to {report_path}')
+    rows.clear()
+
+
+def _write_autotune_artifacts() -> None:
+    reports_dir = _reports_dir_from_argv()
+    if not reports_dir:
+        return
+
+    os.makedirs(reports_dir, exist_ok=True)
+    _write_csv_rows(
+        os.path.join(reports_dir, AUTOTUNE_DECISIONS_FILE),
+        AUTOTUNE_DECISION_FIELDNAMES,
+        AUTOTUNE_DECISION_ROWS,
+    )
+    _write_csv_rows(
+        os.path.join(reports_dir, AUTOTUNE_CANDIDATES_FILE),
+        AUTOTUNE_CANDIDATE_FIELDNAMES,
+        AUTOTUNE_CANDIDATE_ROWS,
+    )
+    AUTOTUNE_DECISION_ROWS.clear()
+
+
+atexit.register(_write_autotune_artifacts)
 
 
