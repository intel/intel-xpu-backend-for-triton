+def _workload_kind(seq_lens: list[tuple[int, int]]) -> str:
+    has_prefill = any(query_len > 1 for query_len, _ in seq_lens)
+    has_decode = any(query_len == 1 for query_len, _ in seq_lens)
+    if has_prefill and has_decode:
+        return 'mixed'
+    return 'prefill' if has_prefill else 'decode'
+
+
+def _effective_max_seqlen_k(seq_lens: list[tuple[int, int]], sliding_window: int | None) -> int:
+    max_seqlen_k = max(kv_len for _, kv_len in seq_lens)
+    if sliding_window is None or sliding_window <= 0:
+        return max_seqlen_k
+    return min(max_seqlen_k, sliding_window)
+
