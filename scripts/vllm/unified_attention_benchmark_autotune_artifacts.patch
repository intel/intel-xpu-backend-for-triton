+def _float_value(value: object) -> float | None:
+    try:
+        result = float(value)
+    except (TypeError, ValueError):
+        return None
+    return result if math.isfinite(result) else None
+
+
+def _timing_value(timing: object, index: int) -> float | None:
+    if isinstance(timing, (list, tuple)):
+        if index >= len(timing):
+            return None
+        return _float_value(timing[index])
+    return _float_value(timing) if index == 0 else None
+
+
+def _summarize_candidate_times(times: list[float]) -> dict[str, float]:
+    timing_tensor = torch.tensor(times, dtype=torch.float)
+    trimmed = sorted(times)[1:-1] if len(times) > 2 else times
+    mean_ms = statistics.fmean(trimmed)
+    stddev_ms = statistics.stdev(trimmed) if len(trimmed) > 1 else 0.0
+    cv = stddev_ms / mean_ms if mean_ms else float('inf')
+    p20_ms, median_ms, p80_ms = torch.quantile(
+        timing_tensor,
+        torch.tensor([0.2, 0.5, 0.8], dtype=torch.float),
+    ).tolist()
+    return {
+        'median_ms': median_ms,
+        'p20_ms': p20_ms,
+        'p80_ms': p80_ms,
+        'mean_ms': mean_ms,
+        'stddev_ms': stddev_ms,
+        'cv': cv,
+    }
+
+
+def _do_bench_with_cv_retry(fn, *, n_warmup: int, n_repeat: int,
+                            quantiles: list[float]) -> tuple[object, ...]:
+    global _LAST_MEASUREMENT_ATTEMPTS
+    attempts: list[tuple[object, ...]] = []
+    for _ in range(AUTOTUNE_MAX_CV_RETRIES + 1):
+        result = tuple(benchmark_suite.do_bench(
+            fn,
+            n_warmup=n_warmup,
+            n_repeat=n_repeat,
+            quantiles=quantiles,
+        ))
+        attempts.append(result)
+        cv = _float_value(result[4])
+        if cv is not None and cv <= AUTOTUNE_CV_THRESHOLD:
+            break
+
+    best = min(
+        attempts,
+        key=lambda result: _float_value(result[4])
+        if _float_value(result[4]) is not None else float('inf'),
+    )
+    _LAST_MEASUREMENT_ATTEMPTS = [
+        {'mean_ms': float(result[3]), 'cv': float(result[4])}
+        for result in attempts
+    ]
+    return best
+
+
+_AUTOTUNE_MARGINS: dict[tuple[tuple[str, str], ...], float] = {}
+
+
+def _key_signature(key_names: list[str],
+                   key_values: dict[str, object]) -> tuple[tuple[str, str], ...]:
+    return tuple((key, _format_csv_value(key_values.get(key, ''))) for key in key_names)
+
+
+def _candidate_do_bench(kernel_call, quantiles):
+    import triton.testing as triton_testing
+
+    attempts: list[dict[str, object]] = []
+    for _ in range(AUTOTUNE_MAX_CV_RETRIES + 1):
+        times = [
+            float(value)
+            for value in triton_testing.do_bench(
+                kernel_call,
+                warmup=25,
+                rep=100,
+                return_mode='all',
+            )
+        ]
+        stats: dict[str, object] = _summarize_candidate_times(times)
+        stats['times'] = times
+        attempts.append(stats)
+        if float(stats['cv']) <= AUTOTUNE_CV_THRESHOLD:
+            break
+
+    best = min(attempts, key=lambda stats: float(stats['cv']))
+    best['timing_attempts'] = len(attempts)
+    best['high_cv'] = float(best['cv']) > AUTOTUNE_CV_THRESHOLD
+    global _CURRENT_CANDIDATE_TIMING
+    _CURRENT_CANDIDATE_TIMING = best
+    values = torch.quantile(
+        torch.tensor(best['times'], dtype=torch.float),
+        torch.tensor(quantiles, dtype=torch.float),
+    ).tolist()
+    return values[0] if len(values) == 1 else values
+
+
+_CURRENT_CANDIDATE_TIMING: dict[str, object] | None = None
+
+
+def _append_candidate_rows(
+    *,
+    kernel: object,
+    key_names: list[str],
+    key_values: dict[str, object],
+    configs_before_prune: list[object],
+    configs_after_prune: list[object],
+    configs_timings: dict[object, object],
+    selected_config: object,
+    cache_hit: bool,
+    tune_duration_s: object,
+) -> None:
+    finite_timings = [
+        (config, _timing_value(timing, 0))
+        for config, timing in configs_timings.items()
+        if _timing_value(timing, 0) is not None
+    ]
+    finite_timings.sort(key=lambda item: item[1])
+    ranks = {id(config): rank for rank, (config, _value) in enumerate(finite_timings, start=1)}
+    margin = ''
+    if len(finite_timings) > 1 and finite_timings[0][1]:
+        margin = (finite_timings[1][1] / finite_timings[0][1] - 1.0) * 100.0
+        _AUTOTUNE_MARGINS[_key_signature(key_names, key_values)] = margin
+
+    for config in configs_before_prune:
+        timing = configs_timings.get(config)
+        stats = _AUTOTUNE_CANDIDATE_TIMINGS.get(id(config), {})
+        row = {
+            **AUTOTUNE_RUN_METADATA,
+            'kernel_name': getattr(getattr(kernel, 'base_fn', None), '__name__', 'kernel_unified_attention'),
+            'autotune_key_names': ';'.join(key_names),
+            'autotune_key_values': _format_csv_value(
+                {key: key_values.get(key, '') for key in key_names}
+            ),
+            'candidate_config': _format_config(config),
+            'pruning_status': (
+                'benchmarked'
+                if config in configs_timings
+                else 'selected_without_benchmark'
+                if config in configs_after_prune and config is selected_config
+                else 'pruned'
+            ),
+            'selected': config is selected_config,
+            'candidate_rank': ranks.get(id(config), ''),
+            'candidates_before_prune': len(configs_before_prune),
+            'candidates_after_prune': len(configs_after_prune),
+            'median_ms': stats.get('median_ms', _timing_value(timing, 0) or ''),
+            'p20_ms': stats.get('p20_ms', _timing_value(timing, 1) or ''),
+            'p80_ms': stats.get('p80_ms', _timing_value(timing, 2) or ''),
+            'mean_ms': stats.get('mean_ms', ''),
+            'stddev_ms': stats.get('stddev_ms', ''),
+            'cv': stats.get('cv', ''),
+            'timing_attempts': stats.get('timing_attempts', ''),
+            'high_cv': stats.get('high_cv', ''),
+            'selected_runner_up_margin_pct': margin,
+            'cache_hit': cache_hit,
+            'tune_duration_s': _format_csv_value(tune_duration_s),
+        }
+        for key in AUTOTUNE_KEY_COLUMNS:
+            row[f'key_{key}'] = key_values.get(key, '')
+        AUTOTUNE_CANDIDATE_ROWS.append(row)
+
+
+def _install_autotune_instrumentation() -> None:
+    kernel = getattr(_unified_attention_module, 'kernel_unified_attention', None)
+    if kernel is None or not hasattr(kernel, 'prune_configs'):
+        return
+
+    original_prune_configs = kernel.prune_configs
+    original_bench = getattr(kernel, '_bench', None)
+    kernel._ua_artifact_original_prune_configs = original_prune_configs
+
+    def recording_prune_configs(kwargs):
+        global _CANDIDATE_EVENT_COUNTER
+        configs_before_prune = list(getattr(kernel, 'configs', []) or [])
+        configs_after_prune = list(original_prune_configs(kwargs))
+        _CANDIDATE_EVENT_COUNTER += 1
+        _LAST_PRUNE_EVENT.clear()
+        _LAST_PRUNE_EVENT.update({
+            'event_id': _CANDIDATE_EVENT_COUNTER,
+            'key_names': list(getattr(kernel, 'keys', []) or []),
+            'key_values': {
+                key: kwargs.get(key, '')
+                for key in list(getattr(kernel, 'keys', []) or [])
+            },
+            'configs_before_prune': configs_before_prune,
+            'configs_after_prune': configs_after_prune,
+            'logged': False,
+        })
+        return configs_after_prune
+
+    kernel.prune_configs = recording_prune_configs
+
