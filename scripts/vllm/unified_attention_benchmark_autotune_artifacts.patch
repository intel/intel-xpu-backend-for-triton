+def _autotune_cache(kernel: object, is_3d: object) -> object:
+    if is_3d is True:
+        cache = getattr(_unified_attention_module, 'UNIFIED_ATTENTION_3D_TILE_CACHE', None)
+        if cache is not None:
+            return cache
+    return getattr(kernel, 'cache', {}) or {}
+
