+def _get_pruned_configs(kernel: object, key_names: list[str],
+                        key_values: dict[str, object]) -> tuple[list[object], str]:
+    if kernel is None or not hasattr(kernel, 'prune_configs'):
+        return [], ''
+
+    old_nargs = getattr(kernel, 'nargs', None)
+    prune_configs = getattr(kernel, '_ua_artifact_original_prune_configs', kernel.prune_configs)
+    meta = {key: key_values.get(key, '') for key in key_names}
+    try:
+        kernel.nargs = {}
+        return list(prune_configs(meta)), ''
+    except Exception as exc:  # pragma: no cover - diagnostic path only
+        return [], f'{type(exc).__name__}:{exc}'
+    finally:
+        try:
+            kernel.nargs = old_nargs
+        except Exception:
+            pass
+
