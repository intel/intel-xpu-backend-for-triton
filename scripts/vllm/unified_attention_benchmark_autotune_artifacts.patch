+def _record_autotune_decision(
+    *,
+    benchmark_name: str,
+    provider: str,
+    q_heads: int,
+    k_heads: int,
+    head_size: int,
+    qdtype: torch.dtype | None,
+    seq_lens: list[tuple[int, int]],
+    sliding_window: int | None,
+    soft_cap: float | None,
+    num_blocks: int,
+    block_size: int,
+    median_ms: float,
+    mean_ms: float,
+    cv: float,
+) -> None:
+    kernel = getattr(_unified_attention_module, 'kernel_unified_attention', None)
+    is_3d = _is_3d()
+    selected_config = None
+    selection_source = 'fixed'
+    if is_3d is True:
+        selected_config = getattr(_unified_attention_module, 'LAST_UNIFIED_ATTENTION_3D_CONFIG', None)
+        if selected_config is not None:
+            selection_source = 'manual_cache'
+    if selected_config is None and kernel is not None:
+        selected_config = getattr(kernel, 'best_config', None)
+        if selected_config is not None:
+            selection_source = 'autotuner'
+    if selected_config is None:
+        selected_config = ''
+
+    key_names = list(getattr(kernel, 'keys', []) or []) if kernel is not None else []
+    key_values = _autotune_key_values(qdtype, head_size, seq_lens, block_size, selected_config, q_heads, k_heads)
+    configs_before_prune = list(getattr(kernel, 'configs', []) or []) if kernel is not None else []
+    pruned_configs, pruning_error = _get_pruned_configs(kernel, key_names, key_values)
+    autotune_cache = _autotune_cache(kernel, is_3d)
+    selected_num_segments = _config_value(selected_config, 'NUM_SEGMENTS_PER_SEQ')
+    if is_3d is True and selected_num_segments == '':
+        selected_num_segments = _observed_value('num_segments', 'num_par_softmax_segments')
+    effective_config = _effective_config(selected_config, q_heads, k_heads)
+    attempts = list(_LAST_MEASUREMENT_ATTEMPTS) or [{'mean_ms': mean_ms, 'cv': cv}]
+    first_cv = attempts[0]['cv']
+    margin = _AUTOTUNE_MARGINS.get(_key_signature(key_names, key_values), '')
+    max_query_len = max(query_len for query_len, _ in seq_lens)
+    max_kv_len = max(kv_len for _, kv_len in seq_lens)
+    context = {
+        'benchmark_name': benchmark_name,
+        'q_heads': q_heads,
+        'k_heads': k_heads,
+        'head_size': head_size,
+        'seq_lens': _format_csv_value(seq_lens),
+        'sliding_window': _format_csv_value(sliding_window),
+        'soft_cap': _format_csv_value(soft_cap),
+        'num_blocks': num_blocks,
+        'block_size': block_size,
+    }
+
+    if _LAST_PRUNE_EVENT and not _LAST_PRUNE_EVENT.get('logged') and selected_config != '':
+        _append_candidate_rows(
+            kernel=kernel,
+            key_names=list(_LAST_PRUNE_EVENT.get('key_names', key_names)),
+            key_values=dict(_LAST_PRUNE_EVENT.get('key_values', key_values)),
+            configs_before_prune=list(_LAST_PRUNE_EVENT.get('configs_before_prune', configs_before_prune)),
+            configs_after_prune=list(_LAST_PRUNE_EVENT.get('configs_after_prune', pruned_configs)),
+            configs_timings={},
+            selected_config=selected_config,
+            cache_hit=True,
+            tune_duration_s='',
+        )
+        _LAST_PRUNE_EVENT['logged'] = True
+
+    decision_signature = _key_signature(key_names, key_values)
+    for candidate_row in AUTOTUNE_CANDIDATE_ROWS:
+        candidate_names = str(candidate_row.get('autotune_key_names', '')).split(';')
+        candidate_values = {
+            key: candidate_row.get(f'key_{key}', '')
+            for key in candidate_names
