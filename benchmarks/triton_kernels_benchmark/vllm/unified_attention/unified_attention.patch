+    "USE_TD",
+    "Q_LEN_BUCKET",
+]
+
+
+def derive_block_q(block_m, num_queries_per_kv):
+    return block_m // num_queries_per_kv
+
+
+def _is_power_of_2(value):
+    return value > 0 and triton.next_power_of_2(value) == value
