+def prune_unified_attention_configs(configs, named_args, **kwargs):
+    """Prune autotune configs for unified_attention kernel."""
+    block_size = kwargs["BLOCK_SIZE"]
+    is_fp8_input = kwargs["IS_FP8_INPUT"]
+    is_3d = kwargs["IS_3D"]
+
+    valid_configs = []
+    for config in configs:
+        tile_size = config.kwargs["TILE_SIZE"]
+
+        if tile_size > block_size:
+            continue
+        if block_size % tile_size != 0:
+            continue
+        if is_fp8_input and tile_size != 32:
+            continue
+
+        if is_3d:
+            fixed_tile_size = 32 if is_fp8_input else 16
+            if tile_size != fixed_tile_size:
+                continue
+
+        valid_configs.append(config)
+
+    return valid_configs
+
+
+@triton.autotune(
+    configs=[
+        triton.Config({"TILE_SIZE": 16}),
+        triton.Config({"TILE_SIZE": 32}),
+    ],
+    key=["BLOCK_SIZE", "HEAD_SIZE", "IS_FP8_INPUT", "IS_3D", "BLOCK_Q"],
+    prune_configs_by={"early_config_prune": prune_unified_attention_configs},
+)
