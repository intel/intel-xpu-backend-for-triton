+ATTENTION_AUTOTUNE_CONFIGS = [
+    triton.Config({"BLOCK_Q": block_q}, num_stages=2)
+    for block_q in (1, 2, 4, 8, 16)
+]
+
+ATTENTION_AUTOTUNE_KEY = [
+    "BLOCK_SIZE",
+    "HEAD_SIZE",
+    "IS_3D",
+    "num_queries_per_kv",
+]
+
+
+def prune_attention_configs(configs, named_args, **kwargs):
+    """Keep BLOCK_Q candidates whose derived BLOCK_M is 16, 32, or 64."""
+    num_queries_per_kv = kwargs["num_queries_per_kv"]
+    valid_configs = []
+    for config in configs:
+        block_q = config.kwargs["BLOCK_Q"]
+        block_m = triton.next_power_of_2(block_q * num_queries_per_kv)
+        if 16 <= block_m <= 64 and block_q == block_m // num_queries_per_kv:
+            valid_configs.append(config)
+    return valid_configs
+
+
+@triton.autotune(
+    configs=ATTENTION_AUTOTUNE_CONFIGS,
+    key=ATTENTION_AUTOTUNE_KEY,
+    prune_configs_by={"early_config_prune": prune_attention_configs},
+)
+@triton.heuristics(
+    {
+        "BLOCK_M": lambda args: triton.next_power_of_2(
+            args["BLOCK_Q"] * args["num_queries_per_kv"]
+        )
+    }
+)
