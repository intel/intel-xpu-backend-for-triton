+# Attention-kernel (num_warps, num_stages) candidates.  num_stages=1 is
+# excluded because the targeted UA sweeps never selected it; stages 2 and 3
+# keep the useful pipelining choices while reducing autotune overhead.
+# num_warps=16 and num_stages=4 are excluded: an on-device winner-logging
+# sweep never selected either across the benchmark shapes (16 warps
+# over-subscribes XPU occupancy; stage-4 pipelining never paid off).
+ATTENTION_WARP_STAGE_CANDIDATES = [
+    (num_warps, num_stages)
+    for num_warps in (2, 4, 8)
+    for num_stages in (2, 3)
+]
+
+# Intel-XPU-specific launch knobs probed only for the attention kernel, where
+# register pressure and DPAS sub-group width matter.  grf_mode='256' gives each
+# thread a larger register file (requires num_warps <= 32); warp_size=16 matches
+# the DPAS sub-group width on PVC/BMG.  Kept as a curated subset (not a full
+# cross product with every warp/stage pair) so the search space stays bounded;
+# the prune callback further trims the BLOCK_M x TILE_SIZE axis per shape.
+ATTENTION_KNOB_VARIANTS = [
+    # (num_warps, num_stages, extra_kwargs)
+    *[(w, s, {}) for w, s in ATTENTION_WARP_STAGE_CANDIDATES],
+    (4, 2, {"grf_mode": "256"}),
+    (8, 2, {"grf_mode": "256"}),
+    (8, 3, {"grf_mode": "256"}),
+    (4, 2, {"warp_size": 16}),
+    (8, 2, {"warp_size": 16}),
+    (8, 2, {"grf_mode": "256", "warp_size": 16}),
+]
+
