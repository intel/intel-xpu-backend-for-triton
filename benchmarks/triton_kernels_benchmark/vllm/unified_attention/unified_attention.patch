+    key=ATTENTION_AUTOTUNE_KEY,
+    prune_configs_by={"early_config_prune": prune_attention_configs},
+)
+@triton.heuristics(
+    {
+        "BLOCK_Q": lambda args: derive_block_q(
+            args["BLOCK_M"], args["num_queries_per_kv"]
+        )
+    }
