+
+def prune_attention_configs(configs, named_args, **kwargs):
+    block_size = kwargs["BLOCK_SIZE"]
+    is_fp8_input = kwargs["IS_FP8_INPUT"]
+    is_3d = kwargs["IS_3D"]
+    num_queries_per_kv = kwargs["num_queries_per_kv"]
+    use_large_head_tile = kwargs["USE_LARGE_HEAD_TILE"]
+    use_td = kwargs["USE_TD"]
+
+    valid_configs = []
+    for config in configs:
+        block_m = config.kwargs["BLOCK_M"]
+        tile_size = config.kwargs["TILE_SIZE"]
+
+        large_head_2d = use_large_head_tile and not is_3d
+        large_head_128_is_legal = large_head_2d and (
+            not use_td or (block_size >= 128 and block_size % 128 == 0)
+        )
+        if large_head_128_is_legal:
+            if tile_size != 128:
+                continue
+        elif tile_size == 128:
+            continue
+
+        # TD descriptor KV loads require TILE_SIZE to divide BLOCK_SIZE.
+        if use_td and tile_size > block_size:
+            continue
+        if use_td and block_size % tile_size != 0:
+            continue
+
+        # TILE_SIZE=16 is not supported for fp8 inputs.
+        if is_fp8_input and tile_size not in (32, 128):
+            continue
+        if not _is_power_of_2(derive_block_q(block_m, num_queries_per_kv)):
+            continue
+
+        valid_configs.append(config)
+
+    return valid_configs
