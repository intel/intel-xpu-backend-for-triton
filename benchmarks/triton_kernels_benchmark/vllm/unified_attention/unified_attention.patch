+ATTENTION_AUTOTUNE_CONFIGS = [
+    triton.Config({"TILE_SIZE": 16}, num_stages=2),
+    triton.Config({"TILE_SIZE": 32}, num_stages=2),
+]
+
+REDUCE_AUTOTUNE_CONFIGS = [
+    triton.Config({"TILE_SIZE": 16}, num_stages=2),
+    triton.Config({"TILE_SIZE": 32}, num_stages=2),
+]
+
+ATTENTION_AUTOTUNE_KEY = [
+    "BLOCK_SIZE",
+    "HEAD_SIZE",
+    "IS_FP8_INPUT",
+    "IS_3D",
+    "BLOCK_Q",
+]
+
+REDUCE_AUTOTUNE_KEY = [
+    "BLOCK_SIZE",
+    "IS_FP8_INPUT",
+]
+
+DEPENDENT_3D_CONFIG_KEYS = ("TILE_SIZE",)
+
+
+def required_3d_shared_config(is_fp8_input):
+    """Return the single legal producer/reducer config for 3D attention."""
+    return {"TILE_SIZE": 32 if is_fp8_input else 16}
+
+
+def _is_valid_shared_config(
+    config, *, block_size, is_fp8_input, is_3d
+):
+    """Validate config values that affect the producer/reducer contract."""
+    if is_3d:
+        required = required_3d_shared_config(is_fp8_input)
+        for key in DEPENDENT_3D_CONFIG_KEYS:
+            if key not in config.kwargs:
+                raise ValueError(f"Missing dependent 3D config value: {key}")
+            if config.kwargs[key] != required[key]:
+                return False
+
+    tile_size = config.kwargs["TILE_SIZE"]
+    if tile_size > block_size or block_size % tile_size != 0:
+        return False
+    if is_fp8_input and tile_size != 32:
+        return False
+
+    return True
+
+
+def _is_valid_attention_local_config(
+    config, *, block_size, is_fp8_input, is_3d
+):
+    """Validate attention-only configs; TILE_SIZE is shared in 3D."""
+    return True
+
+
+def _is_valid_reduce_local_config(
+    config, *, block_size, is_fp8_input, is_3d
+):
+    """Validate reducer-only configs; none exist in the initial config space."""
+    return True
+
+
+def _prune_configs(
+    configs, local_validator, *, block_size, is_fp8_input, is_3d
+):
+    return [
+        config
+        for config in configs
+        if _is_valid_shared_config(
+            config,
+            block_size=block_size,
+            is_fp8_input=is_fp8_input,
+            is_3d=is_3d,
+        )
+        and local_validator(
+            config,
+            block_size=block_size,
+            is_fp8_input=is_fp8_input,
+            is_3d=is_3d,
+        )
+    ]
+
+
+def prune_attention_configs(configs, named_args, **kwargs):
+    return _prune_configs(
+        configs,
+        _is_valid_attention_local_config,
+        block_size=kwargs["BLOCK_SIZE"],
+        is_fp8_input=kwargs["IS_FP8_INPUT"],
+        is_3d=kwargs["IS_3D"],
+    )
+
+
+def prune_reduce_configs(configs, named_args, **kwargs):
+    return _prune_configs(
+        configs,
+        _is_valid_reduce_local_config,
+        block_size=kwargs["BLOCK_SIZE"],
+        is_fp8_input=kwargs["IS_FP8_INPUT"],
+        is_3d=True,
+    )
+
+
+@triton.autotune(
+    configs=ATTENTION_AUTOTUNE_CONFIGS,
+    key=ATTENTION_AUTOTUNE_KEY,
+    prune_configs_by={"early_config_prune": prune_attention_configs},
+)
