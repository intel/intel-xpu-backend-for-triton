+import pytest
+import triton
+
+from vllm.v1.attention.ops.triton_unified_attention import (
+    ATTENTION_AUTOTUNE_CONFIGS,
+    REDUCE_AUTOTUNE_CONFIGS,
+    prune_attention_configs,
+    prune_reduce_configs,
+)
+
+
+def _tile_sizes(configs):
+    return {config.kwargs["TILE_SIZE"] for config in configs}
+
+
+@pytest.mark.parametrize(
+    ("block_size", "is_fp8_input", "expected"),
+    [
+        (16, False, {16}),
+        (64, False, {16}),
+        (64, True, {32}),
+    ],
+)
+def test_3d_shared_tile_is_singleton(block_size, is_fp8_input, expected):
+    kwargs = {
+        "BLOCK_SIZE": block_size,
+        "IS_FP8_INPUT": is_fp8_input,
+        "IS_3D": True,
+    }
+
+    attention_tiles = _tile_sizes(
+        prune_attention_configs(
+            ATTENTION_AUTOTUNE_CONFIGS,
+            None,
+            **kwargs,
+        )
+    )
+    reduce_tiles = _tile_sizes(
+        prune_reduce_configs(
+            REDUCE_AUTOTUNE_CONFIGS,
+            None,
+            **kwargs,
+        )
+    )
+
+    assert attention_tiles == reduce_tiles == expected
+    assert len(attention_tiles) == 1
+
+
+def test_2d_attention_retains_multiple_legal_tiles():
+    attention_tiles = _tile_sizes(
+        prune_attention_configs(
+            ATTENTION_AUTOTUNE_CONFIGS,
+            None,
+            BLOCK_SIZE=64,
+            IS_FP8_INPUT=False,
+            IS_3D=False,
+        )
+    )
+
+    assert attention_tiles == {16, 32}
+
+
+def test_3d_shared_config_requires_tile_size():
+    with pytest.raises(ValueError, match="TILE_SIZE"):
+        prune_reduce_configs(
+            [triton.Config({})],
+            None,
+            BLOCK_SIZE=64,
+            IS_FP8_INPUT=False,
+        )
