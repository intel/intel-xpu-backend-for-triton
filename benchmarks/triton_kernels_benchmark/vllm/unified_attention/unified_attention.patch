+    triton.Config(
+        {"BLOCK_M": block_m, "TILE_SIZE": tile_size, **extra},
+        num_warps=num_warps,
+        num_stages=num_stages,
+    )
+    for block_m in (16, 32, 64)
+    # Keep TILE_SIZE in the autotune config so this axis can be reopened later,
+    # but restrict the current search to the only value that won in analysis.
+    for tile_size in (16,)
+    for num_warps, num_stages, extra in ATTENTION_KNOB_VARIANTS
+]
+
+# reduce_segments is a memory-bound merge with a single short loop.  Analysis
+# selected (num_warps=4, num_stages=2) for every 3D row, so keep that winner
+# plus one low-warp safety config.
+REDUCE_WARP_STAGE_CANDIDATES = [
+    (2, 2),
+    (4, 2),
+]
+
+REDUCE_AUTOTUNE_CONFIGS = [
+    triton.Config({}, num_warps=num_warps, num_stages=num_stages)
+    for num_warps, num_stages in REDUCE_WARP_STAGE_CANDIDATES
+]
+
+# Sequence-shape buckets.  The kernel is shared across decode / chunked / prefill
+# work shapes; a config tuned for one (e.g. grf_mode=256 for a single large
+# prefill sequence) regresses when silently reused for another (many medium
+# prefill sequences, or pure decode).  IS_3D only partially separates these (it
+# is also gated on num_seqs), so we add two low-cardinality buckets derived from
+# the *work shape* rather than raw, high-cardinality num_seqs / seqlen values.
+# Both are plain ints computed host-side and passed as constexprs.
+def q_len_bucket(max_seqlen_q):
+    """Bucket the per-program query length (decode vs chunked vs prefill)."""
+    if max_seqlen_q <= 1:
+        return 0  # pure decode
+    if max_seqlen_q <= 16:
+        return 1  # tiny / chunked-prefill tail
+    if max_seqlen_q <= 512:
+        return 2  # medium prefill
+    return 3  # large prefill
+
+
+def kv_len_bucket(max_seqlen_k):
+    """Bucket the K-loop length (short-context / sliding vs long-context)."""
+    if max_seqlen_k <= 256:
+        return 0
+    if max_seqlen_k <= 1024:
+        return 1
+    if max_seqlen_k <= 4096:
+        return 2
+    return 3
+
+
+# KV_QUANT_MODE, SLIDING_WINDOW and USE_SOFTCAP are added because this kernel is
+# shared across regimes (we do not split into separate kernels): the best launch
+# config differs between them, so they must distinguish autotune cache entries.
+# USE_SOFTCAP gates a per-tile tanh in the inner loop, shifting the
+# compute/register balance enough to change the optimal config.  Q_LEN_BUCKET /
+# KV_LEN_BUCKET capture the dominant work shape so a decode / multi-sequence
+# prefill batch does not reuse a config overfit to a single large-prefill
+# sequence.  All are low-cardinality constexprs in practice.
+ATTENTION_AUTOTUNE_KEY = [
+    "BLOCK_SIZE",
+    "HEAD_SIZE",
+    "IS_FP8_INPUT",
+    "IS_3D",
+    "num_queries_per_kv",
+    "KV_QUANT_MODE",
+    "SLIDING_WINDOW",
+    "USE_SOFTCAP",
+    "Q_LEN_BUCKET",
+    "KV_LEN_BUCKET",
+]
+
+REDUCE_AUTOTUNE_KEY = [
+    "HEAD_SIZE",
+    "HEAD_SIZE_PADDED",
+    "NUM_SEGMENTS_PER_SEQ",
+    "USE_FP8",
+]
+
+
+def derive_block_q(block_m, num_queries_per_kv):
+    return block_m // num_queries_per_kv
+
+
+def _is_power_of_2(value):
+    return value > 0 and (value & (value - 1)) == 0
+
+
+def prune_attention_configs(configs, named_args, **kwargs):
+    """Prune autotune configs for the unified_attention kernel.
+
+    ``BLOCK_M`` is tuned while ``TILE_SIZE`` remains a config field so the axis
+    can be reopened later.  The current config list fixes TILE_SIZE to 16, the
+    only value that won in the targeted analysis.
+
+    ``BLOCK_M`` is only legal when the derived ``BLOCK_Q = BLOCK_M //
+    num_queries_per_kv`` is a positive power of 2 (tensor-descriptor block
+    shapes require it).
+
+    ``TILE_SIZE`` must divide ``BLOCK_SIZE`` and, for fp8 inputs, must be 32
+    (Triton currently fails with ``TILE_SIZE=16`` for fp8). The 3D (decode)
+    path no longer requires the reducer to reconstruct the segment layout from
+    ``TILE_SIZE`` (it relies on the in-kernel ``-inf`` sentinel instead).
+    """
+    block_size = kwargs["BLOCK_SIZE"]
+    is_fp8_input = kwargs["IS_FP8_INPUT"]
+    num_queries_per_kv = kwargs["num_queries_per_kv"]
+
+    valid_configs = []
+    for config in configs:
+        block_m = config.kwargs["BLOCK_M"]
+        tile_size = config.kwargs["TILE_SIZE"]
+
+        if not _is_power_of_2(derive_block_q(block_m, num_queries_per_kv)):
+            continue
+        if tile_size > block_size:
+            continue
+        if block_size % tile_size != 0:
+            continue
+        if is_fp8_input and tile_size != 32:
+            continue
+
+        valid_configs.append(config)
+
+    return valid_configs
+
+
+def prune_reduce_configs(configs, named_args, **kwargs):
+    return configs
+
+
+@triton.autotune(
+    configs=ATTENTION_AUTOTUNE_CONFIGS,
+    key=ATTENTION_AUTOTUNE_KEY,
+    prune_configs_by={"early_config_prune": prune_attention_configs},
+)
+@triton.heuristics(
+    {
+        "BLOCK_Q": lambda args: derive_block_q(
+            args["BLOCK_M"], args["num_queries_per_kv"]
+        )
+    }
